# =============================================================
# Virtual Environment — never commit (300MB+, others use pip)
# =============================================================
venv/
.venv/

# =============================================================
# Environment Variables — NEVER commit secrets to GitHub
# =============================================================
.env
.env.*
!.env.example

# =============================================================
# Python Cache — auto-generated bytecode, not source code
# =============================================================
__pycache__/
*.py[cod]
*.pyo
*.pyd

# =============================================================
# Django Specific
# =============================================================
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal
media/

# =============================================================
# IDE Files — your personal editor settings, irrelevant to others
# =============================================================
.vscode/
.idea/
*.swp
*.swo

# =============================================================
# OS Generated Files
# =============================================================
.DS_Store
Thumbs.db

# =============================================================
# Distribution / Packaging
# =============================================================
dist/
build/
*.egg-info/
node_modules/
